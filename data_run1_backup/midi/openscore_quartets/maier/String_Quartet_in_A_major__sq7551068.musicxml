  <credit page="1">
    <credit-words default-x="954.818327" default-y="2393.00986" justify="center" valign="top">This transcription was produced from an original manuscript (IMSLP# 562387). Only movements 2 and 3 
</credit-words>
    <credit-words>were complete and clear enough to give a reliable transcription, suitable for inclusion in OpenScore String 
</credit-words>
    <credit-words>Quartets. The work that was done on the remaining movements will eventually be included in an academic 
</credit-words>
    <credit-words>paper and a link will be added here to access it.</credit-words>
    </credit>
